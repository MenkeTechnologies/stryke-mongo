## t/test_mongo.stk — assertion tests for the stryke `Mongo` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_mongo.{dylib,so}` on
## `use Mongo`. Live tests use a unique collection `stryke_test_$$` and
## clean up at exit when MongoDB is reachable (defaults to mongodb://
## localhost; override with $MONGODB_URI).

use Mongo

# ── permission-free: cdylib reachable ───────────────────────────────
val $version = Mongo::version()
assert_ok $version, "Mongo::version returns truthy (cdylib loaded)"

# ── liveness probe ──────────────────────────────────────────────────
var %conn
$conn{uri} = $ENV{MONGODB_URI} if defined $ENV{MONGODB_URI}
val $alive = eval { Mongo::ping(%conn) }

if ($alive) {
    val $coll = "stryke_test_$$"
    val $tgt  = "stryke_test.$coll"

    # 1. insert_one
    val $ins1 = Mongo::insert_one($tgt, { name => "alice", age => 30, role => "admin" }, %conn)
    assert_ok defined $ins1->{inserted_id}, "insert_one: returns inserted_id"

    # 2. insert_many
    val $ins2 = Mongo::insert_many($tgt,
        [{ name => "bob", age => 25 },
         { name => "charlie", age => 35 },
         { name => "dana", age => 28 }],
        %conn)
    assert_eq $ins2, 3, "insert_many: inserted=3"

    # 3. count
    assert_eq Mongo::count($tgt, %conn), 4, "count after insert: 4"

    # 4. find with filter+sort+limit
    val @docs = Mongo::find($tgt,
                            filter => { age => { '$gte' => 28 } },
                            sort   => { age => 1 },
                            limit  => 10,
                            %conn)
    assert_eq scalar(@docs), 3, "find ≥28: 3 docs"
    assert_eq $docs[0]->{name}, "dana", "find sorted: smallest age first"

    # 5. find_one
    val $one = Mongo::find_one($tgt, filter => { name => "alice" }, %conn)
    assert_eq $one->{name}, "alice", "find_one: name"
    assert_eq $one->{role}, "admin", "find_one: role"

    # 6. update_one
    val $upd = Mongo::update_one($tgt,
                                { name => "alice" },
                                { '$set' => { role => "superadmin", level => 99 } },
                                %conn)
    assert_eq $upd->{matched_count}, 1, "update_one: matched=1"
    assert_eq $upd->{modified_count}, 1, "update_one: modified=1"

    # 7. aggregate (group by role)
    val @grouped = Mongo::aggregate($tgt,
        [ { '$group' => { _id => '$role', n => { '$sum' => 1 } } } ],
        %conn)
    assert_ge scalar(@grouped), 1, "aggregate: ≥1 group"

    # 8. create_index
    val $idx = Mongo::create_index($tgt, { name => 1 }, unique => 1, %conn)
    assert_eq $idx, "name_1", "create_index: returns index name name_1"

    # 9. delete_many
    val $del = Mongo::delete_many($tgt, {}, %conn)
    assert_eq $del, 4, "delete_many: deleted=4"

    # cleanup
    eval { Mongo::drop_index($tgt, "name_1", %conn) }
}

# ── pure helpers (no connection — always run) ────────────────────────
# `\@` escapes the at-sign so stryke does not array-interpolate it.
val $c = Mongo::parse_connection_string("mongodb://app:s3cret\@h1:27017,h2:27017/shop?replicaSet=rs0")
assert_eq $c->{scheme},   "mongodb", "parse_connection_string: scheme"
assert_eq $c->{srv},      0,         "parse_connection_string: not srv"
assert_eq $c->{user},     "app",     "parse_connection_string: user"
assert_eq scalar(@{ $c->{hosts} }), 2, "parse_connection_string: two hosts"
assert_eq $c->{hosts}[0]{host}, "h1", "parse_connection_string: first host"
assert_eq $c->{hosts}[1]{port}, 27017, "parse_connection_string: second host port"
assert_eq $c->{database}, "shop",    "parse_connection_string: database"
assert_eq $c->{params}{replicaSet}, "rs0", "parse_connection_string: option"

val $srv = Mongo::parse_connection_string("mongodb+srv://u:p\@cluster0.mongodb.net/db")
assert_eq $srv->{srv}, 1, "parse_connection_string: +srv flag"

# build_connection_string: inverse of parse_connection_string.
assert_eq Mongo::build_connection_string(hosts => [{ host => "localhost", port => 27017 }]), "mongodb://localhost:27017", "build_connection_string: bare host"
val $built = Mongo::build_connection_string(hosts => [{ host => "h1", port => 27017 }, { host => "h2", port => 27018 }], database => "shop", params => { replicaSet => "rs0" })
val $rt = Mongo::parse_connection_string($built)
assert_eq scalar(@{ $rt->{hosts} }), 2,      "build_connection_string: round-trips host list"
assert_eq $rt->{database},        "shop",    "build_connection_string: round-trips database"
assert_eq $rt->{params}{replicaSet}, "rs0",  "build_connection_string: round-trips options"
assert_eq Mongo::build_connection_string(srv => 1, hosts => ["cluster0.mongodb.net"], params => { retryWrites => "true" }), "mongodb+srv://cluster0.mongodb.net/?retryWrites=true", "build_connection_string: srv + options-only path"
assert_dies fn { Mongo::build_connection_string(database => "x") }, "build_connection_string: requires hosts"

# redact_connection_string: mask the password for safe logging.
# `\@` escapes the at-sign so stryke does not array-interpolate it.
assert_eq Mongo::redact_connection_string("mongodb://app:s3cret\@h1:27017/shop"), "mongodb://app:***\@h1:27017/shop", "redact: masks the password"
assert_eq Mongo::redact_connection_string("mongodb+srv://u:p\@cluster0.mongodb.net/db?retryWrites=true"), "mongodb+srv://u:***\@cluster0.mongodb.net/db?retryWrites=true", "redact: srv + options preserved"
assert_eq Mongo::redact_connection_string("mongodb://h1:27017/shop"), "mongodb://h1:27017/shop", "redact: no userinfo → unchanged"
assert_eq Mongo::redact_connection_string("mongodb://app\@h1/db"), "mongodb://app\@h1/db", "redact: user without password → unchanged"
assert_eq Mongo::redact_connection_string("mongodb://a:b\@h/db", mask => "X"), "mongodb://a:X\@h/db", "redact: custom mask"
assert_dies fn { Mongo::redact_connection_string("no-scheme") }, "redact: rejects a non-URI"

val $ns = Mongo::parse_namespace("shop.orders.2025")
assert_eq $ns->{db},         "shop",       "parse_namespace: db"
assert_eq $ns->{collection}, "orders.2025", "parse_namespace: collection keeps dots"

# build_namespace: inverse of parse_namespace; rejects a dotted db.
assert_eq Mongo::build_namespace("shop", "orders.2025"), "shop.orders.2025", "build_namespace: joins db.collection"
assert_dies fn { Mongo::build_namespace("a.b", "c") }, "build_namespace: rejects a db containing a dot"

# valid_collection_name: MongoDB collection naming hard rules.
assert_ok Mongo::valid_collection_name("orders")->{valid},       "valid_collection_name: ordinary name"
assert_ok Mongo::valid_collection_name("orders.2025")->{valid},  "valid_collection_name: dots allowed"
assert_eq Mongo::valid_collection_name("with\$dollar")->{valid}, 0, "valid_collection_name: rejects '\$'"
assert_eq Mongo::valid_collection_name("system.users")->{valid}, 0, "valid_collection_name: rejects reserved system. prefix"
assert_eq Mongo::valid_collection_name("")->{valid}, 0,             "valid_collection_name: rejects empty"
val $ns = Mongo::valid_collection_name("c" x 260, "mydb")
assert_eq $ns->{valid}, 0, "valid_collection_name: namespace over 255 bytes with a db"
assert_match qr/255 bytes/, $ns->{reason}, "valid_collection_name: reason names the namespace limit"

# valid_database_name: MongoDB database naming rules (distinct from collections).
assert_ok Mongo::valid_database_name("myapp")->{valid},          "valid_database_name: ordinary name"
assert_eq Mongo::valid_database_name("has.dot")->{valid}, 0,     "valid_database_name: dot forbidden (unlike collections)"
assert_eq Mongo::valid_database_name("has space")->{valid}, 0,   "valid_database_name: space forbidden"
assert_eq Mongo::valid_database_name("with\$dollar")->{valid}, 0, "valid_database_name: '\$' forbidden"
assert_eq Mongo::valid_database_name("")->{valid}, 0,            "valid_database_name: empty rejected"
val $dl = Mongo::valid_database_name("a" x 64)
assert_eq $dl->{valid}, 0,                                       "valid_database_name: 64 chars fails (must be fewer than 64)"
assert_match qr/64/, $dl->{reason},                             "valid_database_name: reason names the limit"

# valid_namespace: validate a full "database.collection" string in one call.
val $vns = Mongo::valid_namespace("myapp.users")
assert_ok $vns->{valid},               "valid_namespace: legal db.collection"
assert_eq $vns->{database},   "myapp",  "valid_namespace: splits the database part"
assert_eq $vns->{collection}, "users",  "valid_namespace: splits the collection part"
assert_eq Mongo::valid_namespace("myapp.sub.coll")->{collection}, "sub.coll", "valid_namespace: splits on the first dot only"
assert_eq Mongo::valid_namespace("justdb")->{valid}, 0,  "valid_namespace: rejects a value with no dot"
val $bad = Mongo::valid_namespace("has space.users")
assert_eq $bad->{valid}, 0,            "valid_namespace: rejects a bad database part"
assert_match qr/database name/, $bad->{reason}, "valid_namespace: reason names the failing part"
assert_eq Mongo::valid_namespace("myapp.us\$ers")->{valid}, 0, "valid_namespace: rejects a bad collection part"

val $oid = Mongo::new_objectid()
assert_eq length($oid), 24, "new_objectid: 24 hex chars"
assert_eq Mongo::is_valid_objectid($oid), 1, "is_valid_objectid: accepts a fresh oid"
assert_eq Mongo::is_valid_objectid("not-an-oid"), 0, "is_valid_objectid: rejects garbage"

# objectid_timestamp: decode the creation time embedded in the leading 4 bytes.
val $ts = Mongo::objectid_timestamp("4d88e15b60f486e428412dc9")
assert_eq $ts->{epoch_seconds}, 1300816219,       "objectid_timestamp: epoch seconds"
assert_eq $ts->{iso}, "2011-03-22T17:50:19Z",      "objectid_timestamp: ISO string"
assert_dies fn { Mongo::objectid_timestamp("nothex") }, "objectid_timestamp rejects a non-ObjectId"

# parse_objectid: decompose all three ObjectId fields.
val $po = Mongo::parse_objectid("4d88e15b60f486e428412dc9")
assert_eq $po->{epoch_seconds}, 1300816219, "parse_objectid: timestamp (bytes 0-3)"
assert_eq $po->{random},        "60f486e428", "parse_objectid: random (bytes 4-8)"
assert_eq $po->{counter},       4271561,     "parse_objectid: counter (bytes 9-11)"
assert_eq $po->{hex},           "4d88e15b60f486e428412dc9", "parse_objectid: hex echoed"
assert_dies fn { Mongo::parse_objectid("nothex") }, "parse_objectid: rejects a non-ObjectId"

# build_objectid: reassemble an ObjectId from its parts (inverse of parse_objectid).
assert_eq Mongo::build_objectid(1300816219, "60f486e428", 4271561)->{oid}, "4d88e15b60f486e428412dc9", "build_objectid: reassembles the canonical vector"
# Round-trips parse_objectid.
val $bp = Mongo::parse_objectid("4d88e15b60f486e428412dc9")
assert_eq Mongo::build_objectid($bp->{epoch_seconds}, $bp->{random}, $bp->{counter})->{oid}, "4d88e15b60f486e428412dc9", "build_objectid: round-trips parse_objectid"
assert_dies fn { Mongo::build_objectid(1, "abc", 0) }, "build_objectid: random must be 10 hex chars"
assert_dies fn { Mongo::build_objectid(1, "0000000000", 16777216) }, "build_objectid: counter out of 24-bit range"

# objectid_from_time: build a boundary ObjectId (driver's createFromTime).
assert_eq Mongo::objectid_from_time(epoch_seconds => 1300816219), "4d88e15b0000000000000000", "objectid_from_time: timestamp in leading 4 bytes, rest zero"
assert_eq Mongo::objectid_from_time(iso => "2011-03-22T17:50:19Z"), "4d88e15b0000000000000000", "objectid_from_time: iso agrees with epoch"
assert_eq Mongo::objectid_timestamp(Mongo::objectid_from_time(epoch_seconds => 1300816219))->{epoch_seconds}, 1300816219, "objectid_from_time: round-trips objectid_timestamp"
assert_dies fn { Mongo::objectid_from_time(epoch_seconds => 5000000000) }, "objectid_from_time: rejects out-of-range timestamp"

# objectid_max_from_time: upper-boundary companion (trailing 0xFF).
assert_eq Mongo::objectid_max_from_time(epoch_seconds => 1300816219), "4d88e15bffffffffffffffff", "objectid_max_from_time: timestamp prefix, rest 0xFF"
assert_ok Mongo::objectid_max_from_time(epoch_seconds => 1300816219) gt Mongo::objectid_from_time(epoch_seconds => 1300816219), "objectid_max_from_time: sorts after the min boundary"
assert_eq Mongo::objectid_timestamp(Mongo::objectid_max_from_time(epoch_seconds => 1300816219))->{epoch_seconds}, 1300816219, "objectid_max_from_time: still decodes to the same second"
assert_eq Mongo::objectid_max_from_time(iso => "2011-03-22T17:50:19Z"), "4d88e15bffffffffffffffff", "objectid_max_from_time: iso agrees with epoch"
assert_dies fn { Mongo::objectid_max_from_time(epoch_seconds => 5000000000) }, "objectid_max_from_time: rejects out-of-range timestamp"

assert_dies fn { Mongo::parse_connection_string("postgres://localhost/x") }, "parse_connection_string rejects non-mongo scheme"

test_run
