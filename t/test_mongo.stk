## t/test_mongo.stk — assertion tests for the stryke `Mongo` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_mongo.{dylib,so}` on
## `use Mongo`. Live tests use a unique collection `stryke_test_$$` and
## clean up at exit when MongoDB is reachable (defaults to mongodb://
## localhost; override with $MONGODB_URI).

use Mongo

# ── permission-free: cdylib reachable ───────────────────────────────
val $version = Mongo::version()
assert_ok $version, "Mongo::version returns truthy (cdylib loaded)"

# ── liveness probe ──────────────────────────────────────────────────
var %conn
$conn{uri} = $ENV{MONGODB_URI} if defined $ENV{MONGODB_URI}
val $alive = eval { Mongo::ping(%conn) }

if ($alive) {
    val $coll = "stryke_test_$$"
    val $tgt  = "stryke_test.$coll"

    # 1. insert_one
    val $ins1 = Mongo::insert_one($tgt, { name => "alice", age => 30, role => "admin" }, %conn)
    assert_ok defined $ins1->{inserted_id}, "insert_one: returns inserted_id"

    # 2. insert_many
    val $ins2 = Mongo::insert_many($tgt,
        [{ name => "bob", age => 25 },
         { name => "charlie", age => 35 },
         { name => "dana", age => 28 }],
        %conn)
    assert_eq $ins2, 3, "insert_many: inserted=3"

    # 3. count
    assert_eq Mongo::count($tgt, %conn), 4, "count after insert: 4"

    # 4. find with filter+sort+limit
    val @docs = Mongo::find($tgt,
                            filter => { age => { '$gte' => 28 } },
                            sort   => { age => 1 },
                            limit  => 10,
                            %conn)
    assert_eq scalar(@docs), 3, "find ≥28: 3 docs"
    assert_eq $docs[0]->{name}, "dana", "find sorted: smallest age first"

    # 5. find_one
    val $one = Mongo::find_one($tgt, filter => { name => "alice" }, %conn)
    assert_eq $one->{name}, "alice", "find_one: name"
    assert_eq $one->{role}, "admin", "find_one: role"

    # 6. update_one
    val $upd = Mongo::update_one($tgt,
                                { name => "alice" },
                                { '$set' => { role => "superadmin", level => 99 } },
                                %conn)
    assert_eq $upd->{matched_count}, 1, "update_one: matched=1"
    assert_eq $upd->{modified_count}, 1, "update_one: modified=1"

    # 7. aggregate (group by role)
    val @grouped = Mongo::aggregate($tgt,
        [ { '$group' => { _id => '$role', n => { '$sum' => 1 } } } ],
        %conn)
    assert_ge scalar(@grouped), 1, "aggregate: ≥1 group"

    # 8. create_index
    val $idx = Mongo::create_index($tgt, { name => 1 }, unique => 1, %conn)
    assert_eq $idx, "name_1", "create_index: returns index name name_1"

    # 8a1. collection_specs — full specs (not just names); our scratch coll is
    # present with type "collection". A filter narrows the listing.
    var @specs = Mongo::collection_specs("stryke_test", %conn)
    assert_ge scalar(@specs), 1, "collection_specs: ≥1 spec for the scratch db"
    var $found_spec = 0
    for val $s (@specs) {
        $found_spec = 1 if $s->{name} eq $coll
    }
    assert_eq $found_spec, 1, "collection_specs: scratch collection appears with its spec"
    val @filtered = Mongo::collection_specs("stryke_test", filter => { name => $coll }, %conn)
    assert_eq scalar(@filtered), 1, "collection_specs: filter narrows to one collection"
    assert_eq $filtered[0]{type}, "collection", "collection_specs: reports type collection"

    # 8a2. validate — server-side integrity check of the collection + indexes.
    val $val = Mongo::validate($tgt, %conn)
    assert_ok $val->{valid}, "validate: scratch collection is valid"
    assert_ge $val->{nIndexes}, 1, "validate: reports at least the _id index"

    # 8b. aggregate_db — database-level pipeline ($listLocalSessions runs against
    # the db, not a collection). Just assert it returns (≥0 docs) without dying.
    val @sess = eval { Mongo::aggregate_db("stryke_test",
        [ { '$listLocalSessions' => +{} } ], %conn) } // ()
    assert_ge scalar(@sess), 0, "aggregate_db: database-level pipeline returns"

    # 8c. drop_indexes — drops every index except _id; idempotent enough to
    # run after create_index. Returns 1.
    assert_eq Mongo::drop_indexes($tgt, %conn), 1, "drop_indexes: returns 1"

    # 9. delete_many
    val $del = Mongo::delete_many($tgt, {}, %conn)
    assert_eq $del, 4, "delete_many: deleted=4"

    # cleanup — drop_database removes the whole scratch db (and its collections).
    eval { Mongo::drop_index($tgt, "name_1", %conn) }
    eval { Mongo::drop_collection($tgt, %conn) }
}

# ── pure helpers (no connection — always run) ────────────────────────
# `\@` escapes the at-sign so stryke does not array-interpolate it.
val $c = Mongo::parse_connection_string("mongodb://app:s3cret\@h1:27017,h2:27017/shop?replicaSet=rs0")
assert_eq $c->{scheme},   "mongodb", "parse_connection_string: scheme"
assert_eq $c->{srv},      0,         "parse_connection_string: not srv"
assert_eq $c->{user},     "app",     "parse_connection_string: user"
assert_eq scalar(@{ $c->{hosts} }), 2, "parse_connection_string: two hosts"
assert_eq $c->{hosts}[0]{host}, "h1", "parse_connection_string: first host"
assert_eq $c->{hosts}[1]{port}, 27017, "parse_connection_string: second host port"
assert_eq $c->{database}, "shop",    "parse_connection_string: database"
assert_eq $c->{params}{replicaSet}, "rs0", "parse_connection_string: option"

val $srv = Mongo::parse_connection_string("mongodb+srv://u:p\@cluster0.mongodb.net/db")
assert_eq $srv->{srv}, 1, "parse_connection_string: +srv flag"

# build_connection_string: inverse of parse_connection_string.
assert_eq Mongo::build_connection_string(hosts => [{ host => "localhost", port => 27017 }]), "mongodb://localhost:27017", "build_connection_string: bare host"
val $built = Mongo::build_connection_string(hosts => [{ host => "h1", port => 27017 }, { host => "h2", port => 27018 }], database => "shop", params => { replicaSet => "rs0" })
val $rt = Mongo::parse_connection_string($built)
assert_eq scalar(@{ $rt->{hosts} }), 2,      "build_connection_string: round-trips host list"
assert_eq $rt->{database},        "shop",    "build_connection_string: round-trips database"
assert_eq $rt->{params}{replicaSet}, "rs0",  "build_connection_string: round-trips options"
assert_eq Mongo::build_connection_string(srv => 1, hosts => ["cluster0.mongodb.net"], params => { retryWrites => "true" }), "mongodb+srv://cluster0.mongodb.net/?retryWrites=true", "build_connection_string: srv + options-only path"
assert_dies fn { Mongo::build_connection_string(database => "x") }, "build_connection_string: requires hosts"

# valid_connection_string: non-throwing host-rule validator.
assert_eq Mongo::valid_connection_string("mongodb://h1:27017,h2:27017/db")->{valid}, 1, "valid_connection_string: standard multi-host is valid"
assert_eq Mongo::valid_connection_string("mongodb+srv://user:pw\@cluster0.mongodb.net/db")->{valid}, 1, "valid_connection_string: srv single host is valid"
val $vp = Mongo::valid_connection_string("mongodb+srv://cluster0.mongodb.net:27017/db")
assert_eq $vp->{valid}, 0, "valid_connection_string: srv rejects a port"
assert_match qr/port/, $vp->{reason}, "valid_connection_string: reason names the port rule"
assert_eq Mongo::valid_connection_string("mongodb+srv://a.net,b.net/db")->{valid}, 0, "valid_connection_string: srv rejects multiple hosts"
assert_eq Mongo::valid_connection_string("postgres://localhost/x")->{valid}, 0, "valid_connection_string: rejects a non-mongo scheme"

# redact_connection_string: mask the password for safe logging.
# `\@` escapes the at-sign so stryke does not array-interpolate it.
assert_eq Mongo::redact_connection_string("mongodb://app:s3cret\@h1:27017/shop"), "mongodb://app:***\@h1:27017/shop", "redact: masks the password"
assert_eq Mongo::redact_connection_string("mongodb+srv://u:p\@cluster0.mongodb.net/db?retryWrites=true"), "mongodb+srv://u:***\@cluster0.mongodb.net/db?retryWrites=true", "redact: srv + options preserved"
assert_eq Mongo::redact_connection_string("mongodb://h1:27017/shop"), "mongodb://h1:27017/shop", "redact: no userinfo → unchanged"
assert_eq Mongo::redact_connection_string("mongodb://app\@h1/db"), "mongodb://app\@h1/db", "redact: user without password → unchanged"
assert_eq Mongo::redact_connection_string("mongodb://a:b\@h/db", mask => "X"), "mongodb://a:X\@h/db", "redact: custom mask"
assert_dies fn { Mongo::redact_connection_string("no-scheme") }, "redact: rejects a non-URI"

val $ns = Mongo::parse_namespace("shop.orders.2025")
assert_eq $ns->{db},         "shop",       "parse_namespace: db"
assert_eq $ns->{collection}, "orders.2025", "parse_namespace: collection keeps dots"

# build_namespace: inverse of parse_namespace; rejects a dotted db.
assert_eq Mongo::build_namespace("shop", "orders.2025"), "shop.orders.2025", "build_namespace: joins db.collection"
assert_dies fn { Mongo::build_namespace("a.b", "c") }, "build_namespace: rejects a db containing a dot"

# valid_collection_name: MongoDB collection naming hard rules.
assert_ok Mongo::valid_collection_name("orders")->{valid},       "valid_collection_name: ordinary name"
assert_ok Mongo::valid_collection_name("orders.2025")->{valid},  "valid_collection_name: dots allowed"
assert_eq Mongo::valid_collection_name("with\$dollar")->{valid}, 0, "valid_collection_name: rejects '\$'"
assert_eq Mongo::valid_collection_name("system.users")->{valid}, 0, "valid_collection_name: rejects reserved system. prefix"
assert_eq Mongo::valid_collection_name("")->{valid}, 0,             "valid_collection_name: rejects empty"
val $ns = Mongo::valid_collection_name("c" x 260, "mydb")
assert_eq $ns->{valid}, 0, "valid_collection_name: namespace over 255 bytes with a db"
assert_match qr/255 bytes/, $ns->{reason}, "valid_collection_name: reason names the namespace limit"

# valid_database_name: MongoDB database naming rules (distinct from collections).
assert_ok Mongo::valid_database_name("myapp")->{valid},          "valid_database_name: ordinary name"
assert_eq Mongo::valid_database_name("has.dot")->{valid}, 0,     "valid_database_name: dot forbidden (unlike collections)"
assert_eq Mongo::valid_database_name("has space")->{valid}, 0,   "valid_database_name: space forbidden"
assert_eq Mongo::valid_database_name("with\$dollar")->{valid}, 0, "valid_database_name: '\$' forbidden"
assert_eq Mongo::valid_database_name("")->{valid}, 0,            "valid_database_name: empty rejected"
val $dl = Mongo::valid_database_name("a" x 64)
assert_eq $dl->{valid}, 0,                                       "valid_database_name: 64 chars fails (must be fewer than 64)"
assert_match qr/64/, $dl->{reason},                             "valid_database_name: reason names the limit"

# valid_namespace: validate a full "database.collection" string in one call.
val $vns = Mongo::valid_namespace("myapp.users")
assert_ok $vns->{valid},               "valid_namespace: legal db.collection"
assert_eq $vns->{database},   "myapp",  "valid_namespace: splits the database part"
assert_eq $vns->{collection}, "users",  "valid_namespace: splits the collection part"
assert_eq Mongo::valid_namespace("myapp.sub.coll")->{collection}, "sub.coll", "valid_namespace: splits on the first dot only"
assert_eq Mongo::valid_namespace("justdb")->{valid}, 0,  "valid_namespace: rejects a value with no dot"
val $bad = Mongo::valid_namespace("has space.users")
assert_eq $bad->{valid}, 0,            "valid_namespace: rejects a bad database part"
assert_match qr/database name/, $bad->{reason}, "valid_namespace: reason names the failing part"
assert_eq Mongo::valid_namespace("myapp.us\$ers")->{valid}, 0, "valid_namespace: rejects a bad collection part"

# escape_regex: backslash-escape PCRE metacharacters for a literal $regex match.
assert_eq Mongo::escape_regex("plain")->{escaped},   "plain",        "escape_regex: plain text unchanged"
assert_eq Mongo::escape_regex("a.b")->{escaped},     "a\\.b",        "escape_regex: dot escaped"
assert_eq Mongo::escape_regex("(x)[y]")->{escaped},  "\\(x\\)\\[y\\]", "escape_regex: parens and brackets escaped"
assert_eq Mongo::escape_regex("a\\b")->{escaped},    "a\\\\b",       "escape_regex: backslash doubled"
assert_eq Mongo::escape_regex("\$9.99")->{escaped},  "\\\$9\\.99",   "escape_regex: dollar and dot escaped"
assert_dies fn { Mongo::escape_regex() }, "escape_regex: dies without a value"

# unescape_regex: inverse of escape_regex (recovers the literal, rejects real patterns).
assert_eq Mongo::unescape_regex("a\\.b")->{value},   "a.b",  "unescape_regex: escaped dot collapses"
assert_eq Mongo::unescape_regex("a\\\\b")->{value},  "a\\b", "unescape_regex: doubled backslash → one"
# Round-trips escape_regex through the FFI boundary.
assert_eq Mongo::unescape_regex(Mongo::escape_regex("\$9.99 (USD)")->{escaped})->{value}, "\$9.99 (USD)", "unescape_regex: round-trips escape_regex"
assert_dies fn { Mongo::unescape_regex("a.b") },  "unescape_regex: rejects an unescaped metacharacter (real regex)"
assert_dies fn { Mongo::unescape_regex("abc\\") }, "unescape_regex: rejects a dangling backslash"

val $oid = Mongo::new_objectid()
assert_eq length($oid), 24, "new_objectid: 24 hex chars"
assert_eq Mongo::is_valid_objectid($oid), 1, "is_valid_objectid: accepts a fresh oid"
assert_eq Mongo::is_valid_objectid("not-an-oid"), 0, "is_valid_objectid: rejects garbage"

# objectid_timestamp: decode the creation time embedded in the leading 4 bytes.
val $ts = Mongo::objectid_timestamp("4d88e15b60f486e428412dc9")
assert_eq $ts->{epoch_seconds}, 1300816219,       "objectid_timestamp: epoch seconds"
assert_eq $ts->{iso}, "2011-03-22T17:50:19Z",      "objectid_timestamp: ISO string"
assert_dies fn { Mongo::objectid_timestamp("nothex") }, "objectid_timestamp rejects a non-ObjectId"

# parse_objectid: decompose all three ObjectId fields.
val $po = Mongo::parse_objectid("4d88e15b60f486e428412dc9")
assert_eq $po->{epoch_seconds}, 1300816219, "parse_objectid: timestamp (bytes 0-3)"
assert_eq $po->{random},        "60f486e428", "parse_objectid: random (bytes 4-8)"
assert_eq $po->{counter},       4271561,     "parse_objectid: counter (bytes 9-11)"
assert_eq $po->{hex},           "4d88e15b60f486e428412dc9", "parse_objectid: hex echoed"
assert_dies fn { Mongo::parse_objectid("nothex") }, "parse_objectid: rejects a non-ObjectId"

# objectid_compare: natural _id sort order (12 bytes lexicographic).
val $cmp = Mongo::objectid_compare("4d88e15b000000000000000a", "5d88e15b000000000000000a")
assert_eq $cmp->{cmp},   -1, "objectid_compare: earlier timestamp sorts first"
assert_eq $cmp->{older}, "4d88e15b000000000000000a", "objectid_compare: older is the earlier id"
assert_eq $cmp->{equal}, 0,  "objectid_compare: distinct ids are not equal"
assert_eq Mongo::objectid_compare("5d88e15b000000000000000a", "4d88e15b000000000000000a")->{cmp}, 1, "objectid_compare: reversed order is +1"
# same second, different counter → the counter breaks the tie (finer than timestamp)
assert_eq Mongo::objectid_compare("4d88e15b0000000000000001", "4d88e15b0000000000000002")->{cmp}, -1, "objectid_compare: counter breaks the same-second tie"
val $same = Mongo::objectid_compare("4d88e15b000000000000000a", "4d88e15b000000000000000a")
assert_eq $same->{equal}, 1,        "objectid_compare: identical ids are equal"
assert_ok !defined($same->{older}), "objectid_compare: equal → older is undef"
assert_dies fn { Mongo::objectid_compare("nothex", "4d88e15b000000000000000a") }, "objectid_compare: rejects an invalid id"

# build_objectid: reassemble an ObjectId from its parts (inverse of parse_objectid).
assert_eq Mongo::build_objectid(1300816219, "60f486e428", 4271561)->{oid}, "4d88e15b60f486e428412dc9", "build_objectid: reassembles the canonical vector"
# Round-trips parse_objectid.
val $bp = Mongo::parse_objectid("4d88e15b60f486e428412dc9")
assert_eq Mongo::build_objectid($bp->{epoch_seconds}, $bp->{random}, $bp->{counter})->{oid}, "4d88e15b60f486e428412dc9", "build_objectid: round-trips parse_objectid"
assert_dies fn { Mongo::build_objectid(1, "abc", 0) }, "build_objectid: random must be 10 hex chars"
assert_dies fn { Mongo::build_objectid(1, "0000000000", 16777216) }, "build_objectid: counter out of 24-bit range"

# objectid_from_time: build a boundary ObjectId (driver's createFromTime).
assert_eq Mongo::objectid_from_time(epoch_seconds => 1300816219), "4d88e15b0000000000000000", "objectid_from_time: timestamp in leading 4 bytes, rest zero"
assert_eq Mongo::objectid_from_time(iso => "2011-03-22T17:50:19Z"), "4d88e15b0000000000000000", "objectid_from_time: iso agrees with epoch"
assert_eq Mongo::objectid_timestamp(Mongo::objectid_from_time(epoch_seconds => 1300816219))->{epoch_seconds}, 1300816219, "objectid_from_time: round-trips objectid_timestamp"
assert_dies fn { Mongo::objectid_from_time(epoch_seconds => 5000000000) }, "objectid_from_time: rejects out-of-range timestamp"

# objectid_max_from_time: upper-boundary companion (trailing 0xFF).
assert_eq Mongo::objectid_max_from_time(epoch_seconds => 1300816219), "4d88e15bffffffffffffffff", "objectid_max_from_time: timestamp prefix, rest 0xFF"
assert_ok Mongo::objectid_max_from_time(epoch_seconds => 1300816219) gt Mongo::objectid_from_time(epoch_seconds => 1300816219), "objectid_max_from_time: sorts after the min boundary"
assert_eq Mongo::objectid_timestamp(Mongo::objectid_max_from_time(epoch_seconds => 1300816219))->{epoch_seconds}, 1300816219, "objectid_max_from_time: still decodes to the same second"
assert_eq Mongo::objectid_max_from_time(iso => "2011-03-22T17:50:19Z"), "4d88e15bffffffffffffffff", "objectid_max_from_time: iso agrees with epoch"
assert_dies fn { Mongo::objectid_max_from_time(epoch_seconds => 5000000000) }, "objectid_max_from_time: rejects out-of-range timestamp"

# objectid_range: inclusive _id boundary pair for a creation-time window.
val $rng = Mongo::objectid_range(+{ epoch_seconds => 1300816219 }, +{ epoch_seconds => 1300902619 })
assert_eq $rng->{min}, "4d88e15b0000000000000000", "objectid_range: min is from_time(start)"
assert_eq $rng->{max}, Mongo::objectid_max_from_time(epoch_seconds => 1300902619), "objectid_range: max is max_from_time(end)"
assert_eq $rng->{start_epoch_seconds}, 1300816219, "objectid_range: reports the start second"
assert_ok $rng->{max} gt $rng->{min}, "objectid_range: max sorts after min"
assert_dies fn { Mongo::objectid_range(+{ epoch_seconds => 100 }, +{ epoch_seconds => 50 }) }, "objectid_range: end before start dies"
assert_dies fn { Mongo::objectid_range(+{ epoch_seconds => 100 }, +{}) }, "objectid_range: a missing time input dies"
assert_dies fn { Mongo::parse_connection_string("postgres://localhost/x") }, "parse_connection_string rejects non-mongo scheme"

# ── pure query builders (no connection — always run) ──────────────────

# merge_filters: disjoint keys → shallow merge; shared key → $and (no clause lost).
val $mf = Mongo::merge_filters([{ status => "active" }, { age => +{ '$gte' => 18 } }])
assert_eq $mf->{status},       "active", "merge_filters: disjoint merge keeps status"
assert_eq $mf->{age}{'$gte'},  18,       "merge_filters: disjoint merge keeps age"
val $mfa = Mongo::merge_filters([{ age => +{ '$gte' => 18 } }, { age => +{ '$lt' => 65 } }])
assert_eq scalar(@{ $mfa->{'$and'} }), 2, "merge_filters: shared key falls back to \$and"
assert_eq scalar(keys %{ Mongo::merge_filters([]) }), 0, "merge_filters: empty → match-all {}"
assert_dies fn { Mongo::merge_filters({ x => 1 }) }, "merge_filters: requires an arrayref"

# build_update: assemble buckets; $unset (array or hash) normalized to "".
val $bu = Mongo::build_update(set => { role => "admin" }, inc => { logins => 1 }, unset => ["tmp"])
assert_eq $bu->{'$set'}{role},   "admin", "build_update: \$set carried"
assert_eq $bu->{'$inc'}{logins}, 1,       "build_update: \$inc carried"
assert_eq $bu->{'$unset'}{tmp},  "",      "build_update: \$unset normalized to empty string"
assert_dies fn { Mongo::build_update() }, "build_update: nothing supplied dies"

# build_sort: "-field" + [field, dir]; order preserved.
val $bs = Mongo::build_sort(["-age", ["name", 1], ["score", "desc"]])
assert_eq $bs->{age},   -1, "build_sort: -age → -1"
assert_eq $bs->{name},   1, "build_sort: [name,1] → 1"
assert_eq $bs->{score}, -1, "build_sort: [score,desc] → -1"
assert_dies fn { Mongo::build_sort([]) }, "build_sort: empty dies"

# build_projection: include / exclude modes + _id exception; mixing dies.
assert_eq Mongo::build_projection(include => ["a", "b"])->{a}, 1, "build_projection: include → 1"
assert_eq Mongo::build_projection(exclude => ["secret"])->{secret}, 0, "build_projection: exclude → 0"
assert_eq Mongo::build_projection(include => ["name"], id => 0)->{_id}, 0, "build_projection: _id may ride opposite mode"
assert_dies fn { Mongo::build_projection(include => ["a"], exclude => ["b"]) }, "build_projection: mixing modes dies"

# normalize_index_keys: directions + string index types; compound order preserved.
val $nk = Mongo::normalize_index_keys(["-created", ["loc", "2dsphere"], ["name", 1]])
assert_eq $nk->{created}, -1,         "normalize_index_keys: -created → -1"
assert_eq $nk->{loc},     "2dsphere", "normalize_index_keys: string type passes through"
assert_eq $nk->{name},     1,         "normalize_index_keys: [name,1] → 1"
assert_dies fn { Mongo::normalize_index_keys([["f", 2]]) }, "normalize_index_keys: bad direction dies"

# in_filter / between_filter: operator builders.
assert_eq Mongo::in_filter("status", ["a", "b"])->{status}{'$in'}[1], "b", "in_filter: \$in list"
assert_eq Mongo::in_filter("status", ["x"], negate => 1)->{status}{'$nin'}[0], "x", "in_filter: negate → \$nin"
val $bt = Mongo::between_filter("age", gte => 18, lt => 65)
assert_eq $bt->{age}{'$gte'}, 18, "between_filter: lower inclusive bound"
assert_eq $bt->{age}{'$lt'},  65, "between_filter: upper exclusive bound"
assert_dies fn { Mongo::between_filter("x", gte => 1, gt => 2) }, "between_filter: bound + strict variant dies"
assert_dies fn { Mongo::between_filter("x") }, "between_filter: no bound dies"

# build_regex_filter: literal escaping + anchoring + ignore_case.
assert_eq Mongo::build_regex_filter("name", "a.b", anchor => "exact")->{name}{'$regex'}, "^a\\.b\$", "build_regex_filter: literal . escaped, exact-anchored"
val $brp = Mongo::build_regex_filter("name", "foo", anchor => "prefix", ignore_case => 1)
assert_eq $brp->{name}{'$regex'},   "^foo", "build_regex_filter: prefix anchor"
assert_eq $brp->{name}{'$options'}, "i",    "build_regex_filter: ignore_case adds i option"
assert_dies fn { Mongo::build_regex_filter("f", "x", anchor => "bad") }, "build_regex_filter: bad anchor dies"

# or_filter: disjunctive companion to merge_filters. 0 → {}, 1 → pass-through, 2+ → $or.
val $orf = Mongo::or_filter([{ a => 1 }, { b => 2 }])
assert_eq scalar(@{ $orf->{'$or'} }), 2, "or_filter: two clauses → \$or array"
assert_eq $orf->{'$or'}[1]{b}, 2, "or_filter: second clause preserved"
assert_eq Mongo::or_filter([{ a => 1 }])->{a}, 1, "or_filter: single filter returned unchanged"
assert_eq scalar(keys %{ Mongo::or_filter([]) }), 0, "or_filter: empty → match-all {}"
assert_dies fn { Mongo::or_filter({ x => 1 }) }, "or_filter: requires an arrayref"

# exists_filter: defaults to true; honors explicit false. (the cdylib emits a
# JSON bool; stryke decodes JSON true→1 / false→0.)
assert_eq Mongo::exists_filter("email")->{email}{'$exists'}, 1, "exists_filter: defaults to \$exists true"
assert_eq Mongo::exists_filter("email", exists => 0)->{email}{'$exists'}, 0, "exists_filter: explicit false"

# elem_match_filter: whole query binds to one array element.
val $em = Mongo::elem_match_filter("scores", { '$gte' => 80, '$lt' => 90 })
assert_eq $em->{scores}{'$elemMatch'}{'$gte'}, 80, "elem_match_filter: lower bound under \$elemMatch"
assert_eq $em->{scores}{'$elemMatch'}{'$lt'},  90, "elem_match_filter: upper bound under \$elemMatch"
assert_dies fn { Mongo::elem_match_filter("f", "notahash") }, "elem_match_filter: query must be a hashref"

# text_filter: $text/$search with optional knobs; minimal call carries no extras.
val $tf = Mongo::text_filter("coffee shop")
assert_eq $tf->{'$text'}{'$search'}, "coffee shop", "text_filter: \$search carried"
assert_ok !exists $tf->{'$text'}{'$language'}, "text_filter: no phantom \$language when unset"
val $tff = Mongo::text_filter("cafe", language => "fr", case_sensitive => 1)
assert_eq $tff->{'$text'}{'$language'},      "fr", "text_filter: language carried"
assert_eq $tff->{'$text'}{'$caseSensitive'}, 1, "text_filter: case_sensitive carried"

# not_filter: wraps an operator expression; rejects bare value / logical ops.
assert_eq Mongo::not_filter("age", { '$gt' => 5 })->{age}{'$not'}{'$gt'}, 5, "not_filter: wraps operator under \$not"
assert_dies fn { Mongo::not_filter("f", { a => 1 }) }, "not_filter: rejects a non-operator field key"
assert_dies fn { Mongo::not_filter("f", { '$or' => [{ a => 1 }] }) }, "not_filter: rejects a logical operator"
assert_dies fn { Mongo::not_filter("f", "notahash") }, "not_filter: expr must be a hashref"

test_run
