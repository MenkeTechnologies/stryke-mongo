## t/test_mongo.stk — assertion tests for the stryke `Mongo` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_mongo.{dylib,so}` on
## `use Mongo`. Live tests use a unique collection `stryke_test_$$` and
## clean up at exit when MongoDB is reachable (defaults to mongodb://
## localhost; override with $MONGODB_URI).

use Mongo

# ── permission-free: cdylib reachable ───────────────────────────────
val $version = Mongo::version()
assert_ok $version, "Mongo::version returns truthy (cdylib loaded)"

# ── liveness probe ──────────────────────────────────────────────────
var %conn
$conn{uri} = $ENV{MONGODB_URI} if defined $ENV{MONGODB_URI}
val $alive = eval { Mongo::ping(%conn) }

if ($alive) {
    val $coll = "stryke_test_$$"
    val $tgt  = "stryke_test.$coll"

    # 1. insert_one
    val $ins1 = Mongo::insert_one($tgt, { name => "alice", age => 30, role => "admin" }, %conn)
    assert_ok defined $ins1->{inserted_id}, "insert_one: returns inserted_id"

    # 2. insert_many
    val $ins2 = Mongo::insert_many($tgt,
        [{ name => "bob", age => 25 },
         { name => "charlie", age => 35 },
         { name => "dana", age => 28 }],
        %conn)
    assert_eq $ins2, 3, "insert_many: inserted=3"

    # 3. count
    assert_eq Mongo::count($tgt, %conn), 4, "count after insert: 4"

    # 4. find with filter+sort+limit
    val @docs = Mongo::find($tgt,
                            filter => { age => { '$gte' => 28 } },
                            sort   => { age => 1 },
                            limit  => 10,
                            %conn)
    assert_eq scalar(@docs), 3, "find ≥28: 3 docs"
    assert_eq $docs[0]->{name}, "dana", "find sorted: smallest age first"

    # 5. find_one
    val $one = Mongo::find_one($tgt, filter => { name => "alice" }, %conn)
    assert_eq $one->{name}, "alice", "find_one: name"
    assert_eq $one->{role}, "admin", "find_one: role"

    # 6. update_one
    val $upd = Mongo::update_one($tgt,
                                { name => "alice" },
                                { '$set' => { role => "superadmin", level => 99 } },
                                %conn)
    assert_eq $upd->{matched_count}, 1, "update_one: matched=1"
    assert_eq $upd->{modified_count}, 1, "update_one: modified=1"

    # 7. aggregate (group by role)
    val @grouped = Mongo::aggregate($tgt,
        [ { '$group' => { _id => '$role', n => { '$sum' => 1 } } } ],
        %conn)
    assert_ge scalar(@grouped), 1, "aggregate: ≥1 group"

    # 8. create_index
    val $idx = Mongo::create_index($tgt, { name => 1 }, unique => 1, %conn)
    assert_eq $idx, "name_1", "create_index: returns index name name_1"

    # 9. delete_many
    val $del = Mongo::delete_many($tgt, {}, %conn)
    assert_eq $del, 4, "delete_many: deleted=4"

    # cleanup
    eval { Mongo::drop_index($tgt, "name_1", %conn) }
}

test_run
