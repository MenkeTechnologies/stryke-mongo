## t/test_stryke_mongo_surface.stk — wrapper-completeness pin.
##
## Asserts every public `fn X::Y::name` declared in lib/*.stk is
## reachable via `use` at runtime. Uses `exists &X::Y::name` to
## probe the symbol table without invoking the sub.
##
## Catches:
##   * a wrapper sub deleted from lib/ but still referenced elsewhere
##   * a sub-package file dropped from the install layout
##   * `use Foo::Bar` failing to chase into lib/Bar.stk
##   * an installed-package entry whose namespace bridge is broken
##
## Permission-free — no service, no creds, no live daemon. Private
## helpers (`_` prefix) are implementation detail and are NOT
## asserted, so refactoring internals stays free.

use Mongo

# ── Mongo.stk ──────────────────────────────────────────────
assert_ok exists &Mongo::version, "Mongo::version exists"
assert_ok exists &Mongo::ping, "Mongo::ping exists"
assert_ok exists &Mongo::list_databases, "Mongo::list_databases exists"
assert_ok exists &Mongo::list_collections, "Mongo::list_collections exists"
assert_ok exists &Mongo::find, "Mongo::find exists"
assert_ok exists &Mongo::find_one, "Mongo::find_one exists"
assert_ok exists &Mongo::count, "Mongo::count exists"
assert_ok exists &Mongo::aggregate, "Mongo::aggregate exists"
assert_ok exists &Mongo::find_stream, "Mongo::find_stream exists"
assert_ok exists &Mongo::insert_one, "Mongo::insert_one exists"
assert_ok exists &Mongo::insert_many, "Mongo::insert_many exists"
assert_ok exists &Mongo::update_one, "Mongo::update_one exists"
assert_ok exists &Mongo::update_many, "Mongo::update_many exists"
assert_ok exists &Mongo::replace_one, "Mongo::replace_one exists"
assert_ok exists &Mongo::delete_one, "Mongo::delete_one exists"
assert_ok exists &Mongo::delete_many, "Mongo::delete_many exists"
assert_ok exists &Mongo::create_index, "Mongo::create_index exists"
assert_ok exists &Mongo::drop_index, "Mongo::drop_index exists"
assert_ok exists &Mongo::indexes, "Mongo::indexes exists"
assert_ok exists &Mongo::find_one_and_update, "Mongo::find_one_and_update exists"
assert_ok exists &Mongo::find_one_and_replace, "Mongo::find_one_and_replace exists"
assert_ok exists &Mongo::find_one_and_delete, "Mongo::find_one_and_delete exists"
assert_ok exists &Mongo::distinct, "Mongo::distinct exists"
assert_ok exists &Mongo::estimated_count, "Mongo::estimated_count exists"
assert_ok exists &Mongo::create_collection, "Mongo::create_collection exists"
assert_ok exists &Mongo::drop_collection, "Mongo::drop_collection exists"
assert_ok exists &Mongo::run_command, "Mongo::run_command exists"
assert_ok exists &Mongo::exists, "Mongo::exists exists"
assert_ok exists &Mongo::find_value, "Mongo::find_value exists"
assert_ok exists &Mongo::collection_exists, "Mongo::collection_exists exists"

# ── Mongo.stk admin/stats extras ──
assert_ok exists &Mongo::rename_collection, "Mongo::rename_collection exists"
assert_ok exists &Mongo::coll_stats, "Mongo::coll_stats exists"
assert_ok exists &Mongo::db_stats, "Mongo::db_stats exists"

assert_ok exists &Mongo::explain, "Mongo::explain exists"
assert_ok exists &Mongo::server_status, "Mongo::server_status exists"

assert_ok exists &Mongo::create_indexes, "Mongo::create_indexes exists"

# ── pure ObjectId / namespace helpers ──
assert_ok exists &Mongo::parse_connection_string, "Mongo::parse_connection_string exists"
assert_ok exists &Mongo::build_connection_string, "Mongo::build_connection_string exists"
assert_ok exists &Mongo::redact_connection_string, "Mongo::redact_connection_string exists"
assert_ok exists &Mongo::parse_namespace, "Mongo::parse_namespace exists"
assert_ok exists &Mongo::build_namespace, "Mongo::build_namespace exists"
assert_ok exists &Mongo::valid_collection_name, "Mongo::valid_collection_name exists"
assert_ok exists &Mongo::valid_database_name, "Mongo::valid_database_name exists"
assert_ok exists &Mongo::is_valid_objectid, "Mongo::is_valid_objectid exists"
assert_ok exists &Mongo::new_objectid, "Mongo::new_objectid exists"
assert_ok exists &Mongo::objectid_timestamp, "Mongo::objectid_timestamp exists"
assert_ok exists &Mongo::parse_objectid, "Mongo::parse_objectid exists"
assert_ok exists &Mongo::objectid_from_time, "Mongo::objectid_from_time exists"
test_run
